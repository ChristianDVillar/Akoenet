{
  "name": "akonet-backend",
  "version": "1.2.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate.js up",
    "migrate:down": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate.js down",
    "migrate:create": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate.js create",
    "migrate:fix-order": "node -r dotenv/config scripts/fix-pgmigrations-gap.js",
    "migrate:fix-order:reseed": "node -r dotenv/config scripts/fix-pgmigrations-gap.js --reseed",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@2toad/profanity": "^3.3.0",
    "@aws-sdk/client-s3": "^3.1018.0",
    "@aws-sdk/s3-request-presigner": "^3.1018.0",
    "@elastic/elasticsearch": "^8.19.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "file-type": "^16.5.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-pg-migrate": "^8.0.4",
    "otplib": "^12.0.1",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "socket.io": "^4.7.5",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
