PORT=3000
LOG_LEVEL=info
JWT_SECRET=change-me-in-production
TOKEN_VERSION=2
DATABASE_URL=postgresql://postgres:1234@localhost:5432/akonet
REDIS_URL=redis://localhost:6379
STORAGE_DRIVER=local
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=akonet
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# For S3/MinIO public URL generation:
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/akonet
# Serve S3 files through backend with short-lived signed URLs:
S3_USE_PRESIGNED_URLS=true
# 60..3600 seconds (default 900)
S3_SIGNED_URL_TTL_SECONDS=900
# Upload rate limit: requests per minute per IP
UPLOAD_RATE_LIMIT_MAX=20
# Auth rate limit: requests per minute per IP
AUTH_RATE_LIMIT_MAX=10
# Socket message rate limits: events per minute per user
SOCKET_MESSAGE_RATE_LIMIT_MAX=40
SOCKET_DM_RATE_LIMIT_MAX=30
# Reactions rate limit: requests per minute per IP
REACTION_RATE_LIMIT_MAX=10
# Export safety cap: max messages per channel export
EXPORT_MAX_MESSAGES=10000
