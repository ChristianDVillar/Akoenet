PORT=3000
LOG_LEVEL=info
JWT_SECRET=change-me-in-production
TOKEN_VERSION=2
# Bump when Terms / Privacy text changes materially; users must re-accept via /auth/terms/accept.
# LEGAL_TERMS_VERSION=1
# Access JWT lifetime (default 30m). Short access + refresh rotation = safer sessions.
# JWT_EXPIRES_IN=15m
# Duplicate text in same channel within N seconds (anti-flood); default 60, max 300
# CHAT_DUPLICATE_WINDOW_SEC=60
# Refresh token storage (table refresh_tokens); lifetime in days (default 30).
# REFRESH_TOKEN_EXPIRES_DAYS=30
# Prometheus scrape at GET /metrics (no JWT; protect with network/firewall).
# PROMETHEUS_METRICS_ENABLED=1
# Link preview (Open Graph) fetches per IP per minute
# LINK_PREVIEW_RATE_LIMIT_MAX=20
# Optional Elasticsearch for global message search (falls back to PostgreSQL if unset)
# ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_MESSAGES_INDEX=akonet-messages
# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# Native Android push (FCM via firebase-admin): JSON completo de service account en una sola línea.
# Si contiene saltos de línea, escápalos o usa formato JSON minificado.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
# Local Postgres (npm run dev desde backend/)
DATABASE_URL=postgresql://postgres:1234@localhost:5432/akonet
# Docker Compose: host del servicio postgres, no localhost
# DATABASE_URL=postgresql://postgres:1234@postgres:5432/akonet
# Opcional — solo si integras cliente/SDK de Supabase además del backend Node:
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# Supabase — Session pooler (recomendado; IPv4 + IPv6). Dashboard → Connect → Session pooler.
# Formato típico (prefijo aws-0- / aws-1- según el panel). Usa sslmode=no-verify con Node/pg + pooler
# si ves SELF_SIGNED_CERT_IN_CHAIN; sigue siendo conexión cifrada TLS.
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=no-verify
# Conexión DIRECTA (db.xxxxx.supabase.co:5432) suele ser solo IPv6; si ves ENOTFOUND, usa el pooler arriba.
# Hosted DB: skip hardcoded dev admin seed (optional first admin via register + SQL is_admin, or ADMIN_BOOTSTRAP_*)
# SKIP_ADMIN_BOOTSTRAP=1
# ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_EMAIL=you@example.com
# ADMIN_BOOTSTRAP_PASSWORD_HASH=$2a$10$... (bcrypt)
# Opcional: adapter Socket.IO multi-instancia. Si no hay Redis, comenta la línea o deja vacío;
# el backend arranca igual (modo un solo proceso). Con Docker: docker compose up -d redis
REDIS_URL=redis://localhost:6379
STORAGE_DRIVER=local
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=akonet
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# For S3/MinIO public URL generation:
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/akonet
# Serve S3 files through backend with short-lived signed URLs:
S3_USE_PRESIGNED_URLS=true
# 60..3600 seconds (default 900)
S3_SIGNED_URL_TTL_SECONDS=900
# Broad API rate limit: requests per minute per IP (health/docs excluded).
# Default if unset: 400 in development, 200 in production (NODE_ENV=production).
GLOBAL_RATE_LIMIT_MAX=400
# Postgres pool size (pg Pool `max`)
DATABASE_POOL_MAX=20
# Upload rate limit: requests per minute per IP
UPLOAD_RATE_LIMIT_MAX=20
# Auth rate limit: requests per minute per IP
AUTH_RATE_LIMIT_MAX=10
# User profile/settings updates: requests per minute per IP
USER_DATA_RATE_LIMIT_MAX=20
# Socket message rate limits: events per minute per user
SOCKET_MESSAGE_RATE_LIMIT_MAX=40
SOCKET_DM_RATE_LIMIT_MAX=30
# Reactions rate limit: requests per minute per IP
REACTION_RATE_LIMIT_MAX=10
# Content report rate limit: requests per minute per IP
REPORT_RATE_LIMIT_MAX=15
# Blocked language (profanity) filter for messages and profile text. Uses npm @2toad/profanity lists (similar approach to many community apps).
# BLOCKED_WORDS_ENABLED=true
# Comma-separated language codes (built-in lists): en, es, de, fr, ...
# BLOCKED_WORDS_LANGUAGES=en,es
# Extra blocked words (comma-separated), merged with built-in lists
# BLOCKED_WORDS=
# Optional path: one word per line, # starts a comment line
# BLOCKED_WORDS_FILE=
# Export safety cap: max messages per channel export
EXPORT_MAX_MESSAGES=10000
TWITCH_CLIENT_ID=put-your-real-twitch-client-id
TWITCH_CLIENT_SECRET=put-your-real-twitch-client-secret
# Optional: override auto-derived callback (must match Twitch Developer Console exactly).
# If unset: TWITCH_REDIRECT_URI = {resolved public API}/auth/twitch/callback
# Same routes are also mounted at /api/user/auth/... if you registered that path in Twitch.
# TWITCH_REDIRECT_URI=http://localhost:3000/auth/twitch/callback
# Steam Web API (game activity + “link Steam”). Register at https://steamcommunity.com/dev/apikey — never commit the real key.
# Callback route: {PUBLIC_API_URL or RENDER_EXTERNAL_URL}/auth/steam/callback
# STEAM_WEB_API_KEY=
# Public API origin. On Render: either omit this and rely on RENDER_EXTERNAL_URL, or set your HTTPS API URL.
# Do not set PUBLIC_API_URL to http://localhost:3000 on Render (it breaks Twitch OAuth); leave unset or use real URL.
# Ejemplo producción: https://akoenet-backend.onrender.com
PUBLIC_API_URL=http://localhost:3000
# SPA origin for OAuth return. On Render (RENDER=true), defaults to https://akoenet-frontend.onrender.com if unset.
# Ejemplo producción: https://akoenet-frontend.onrender.com
FRONTEND_URL=http://localhost:5173
# Optional: absolute URL to logo if inline file is missing (prefer embedding; see MAIL_LOGO_PATH).
# EMAIL_LOGO_URL=https://your-frontend.example/Akoenet.png
# Optional: path to Akoenet.png on the server (Docker / production) when repo layout differs
# MAIL_LOGO_PATH=/app/frontend/public/Akoenet.png
# If the SPA uses HashRouter, set true so verification links use /#/register/complete?token=...
# On Render, defaults to true when RENDER=true (matches frontend/vite HashRouter default).
# Set false only if the SPA is built with VITE_USE_HASH_ROUTER=false and static rewrites serve index.html for all paths.
# FRONTEND_HASH_ROUTER=
# Optional legacy: not used for Twitch return URL anymore (SPA uses /?twitch_token= on FRONTEND_URL).
# FRONTEND_OAUTH_REDIRECT=http://localhost:5173/auth/twitch/callback
# Streamer Scheduler sends this value in header x-scheduler-webhook-secret; must match Scheduler's SCHEDULER_WEBHOOK_SECRET exactly (same string on Render for both services). Paste the full secret; no extra surrounding quotes unless they belong to the secret. Special characters (&, =, %, `, #, ", etc.) are fine.
SCHEDULER_WEBHOOK_SECRET=change-me
SCHEDULER_ANNOUNCE_CHANNEL_ID=
SCHEDULER_ANNOUNCER_USER_ID=
# Optional avatar URL used for !schedule / !next bot replies (shown as "Scheduler").
# You can point this to your own hosted logo, e.g. https://.../RoundLogoBlack.png
# Default fallback in code: FRONTEND_URL + /Akoenet.png (or https://akoenet-frontend.onrender.com/Akoenet.png)
SCHEDULER_BOT_AVATAR_URL=
# Outbound: Streamer Scheduler JSON API (not the SPA). Base = API host (e.g. https://api.streamautomator.com).
SCHEDULER_API_BASE_URL=
# Path relative to base; {username} = Scheduler account username (Settings profile), not always Twitch login.
# Default matches Streamer Scheduler: GET /api/streamer/:username/events
SCHEDULER_UPCOMING_PATH=/api/streamer/{username}/events
# Optional: full URL (overrides base+path), e.g. https://api.example.com/api/streamer/{username}/events
SCHEDULER_UPCOMING_URL_TEMPLATE=
SCHEDULER_API_TOKEN=
# Optional: default Scheduler slug when !schedule / sidebar has no Twitch user or ?username=
# (Users can set their slug in User settings if Twitch login ≠ Scheduler account.)
SCHEDULER_DEFAULT_STREAMER_USERNAME=
# Per-minute limit for !schedule / !next commands per user (Socket)
SCHEDULER_SOCKET_RATE_LIMIT_MAX=15
# Max lines in !schedule list output (default 5)
SCHEDULER_LIST_MAX=5
# GET /health/deps → deps.scheduler (discovery) when SCHEDULER_API_BASE_URL is set
# GET /integrations/scheduler/discovery — public proxy to Scheduler /api/integration/akoenet
#
# HTTP 502 on /integrations/scheduler/* in the browser: the backend reached the route but could not
# get a valid JSON response from SCHEDULER_API_BASE_URL (wrong URL, Scheduler down, or network).
# Configure SCHEDULER_API_* or ignore the widget until the Scheduler is reachable.
# A 502 on every API path from Render usually means the web service is waking up, crashed, or unhealthy—check Render logs.

# Optional strict CORS allowlist (comma-separated origins). If empty, all origins are allowed.
# Example: CORS_ORIGINS=https://akoenet-frontend.onrender.com,http://localhost:5173
# Tauri desktop uses https://tauri.localhost (allowed automatically even if not listed here).
CORS_ORIGINS=

# --- Legal & compliance (optional) ---
# Inbox for DMCA team copies and DPO operator notifications (default: akonet@streamautomator.com).
# Override only if you use another mailbox; sensitive/legal mail should reach the operator.
# LEGAL_INBOX_EMAIL=akonet@streamautomator.com
#
# Data Protection Officer / public contact (GET /dpo/contact). If DPO_EMAIL is empty, the legal inbox above is shown.
DPO_NAME=
DPO_EMAIL=
DPO_PHONE=
DPO_ADDRESS=

# Production HTTPS: redirect HTTP→HTTPS when NODE_ENV=production. Set FORCE_HTTPS=false to disable (e.g. local prod test).
# FORCE_HTTPS=true
# Behind nginx/Caddy/Render: trust X-Forwarded-Proto so req.secure is correct.
# TRUST_PROXY=1

# Scheduled DB dumps: directory the host writes to; GET /admin/backup-status lists *.sql.gz here (admin JWT).
# BACKUP_DIR=/var/backups/akoenet

# Public DMCA/DPO form rate limit (per IP per minute)
# LEGAL_FORMS_RATE_LIMIT_MAX=8

# --- Resend (transactional email) ---
# https://resend.com — do not commit real keys. Same domain can serve StreamAutomator + AkoeNet with different "from".
RESEND_API_KEY=
# Default if unset: AkoeNet <akonet@streamautomator.com>
# RESEND_FROM=AkoeNet <akonet@streamautomator.com>
# Extra comma-separated recipients for DMCA notices (LEGAL_INBOX_EMAIL is always included first)
# DMCA_NOTIFY_EMAIL=
# ADMIN_NOTIFY_EMAIL=
