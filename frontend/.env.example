VITE_API_URL=http://localhost:3000
# Shown in the public footer (“Proyecto y desarrollo por …”).
# VITE_APP_AUTHOR=Tu nombre
# JSON array for WebRTC ICE servers.
# Example with STUN + TURN:
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
# Optional override for the sidebar “Upcoming streams” widget. If unset, the backend uses your
# Twitch login after you sign in with Twitch (users.twitch_username), then SCHEDULER_DEFAULT_STREAMER_USERNAME.
# VITE_SCHEDULER_STREAMER_USERNAME=yourname
