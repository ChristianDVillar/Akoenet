# Backend API (Socket.IO + REST). Local dev:
VITE_API_URL=http://localhost:3000
# Producción pública (Render): en `npm run build` / `tauri:build`, si NO defines VITE_API_URL, el bundle usa
# https://akoenet-backend.onrender.com (ver src/lib/apiBase.js). Si dejas localhost aquí y construyes un .exe/.msi,
# ese instalador intentará http://localhost:3000 en la máquina del usuario y fallará: antes del release comenta
# VITE_API_URL o usa `VITE_API_URL=https://akoenet-backend.onrender.com`. En builds PROD, localhost en VITE_API_URL
# se ignora y se usa el host público, salvo que pongas VITE_API_URL_STRICT=true (solo pruebas locales del bundle).
# VITE_API_URL=https://akoenet-backend.onrender.com
# VITE_API_URL_STRICT=true
#
# Frontend público (SPA): https://akoenet-frontend.onrender.com — útil para enlaces de invitación si desarrollas en local:
# VITE_PUBLIC_ORIGIN=https://akoenet-frontend.onrender.com
# Router: Render sets RENDER=true at build time → HashRouter (#/server/1) so deep links work without a CDN rewrite.
# Set to false if you configure Static Site rewrite /* → /index.html and want clean /server/1 URLs.
# VITE_USE_HASH_ROUTER=false
# Local: set true to test HashRouter: VITE_USE_HASH_ROUTER=true
# Shown in the public footer (“Proyecto y desarrollo por …”).
# VITE_APP_AUTHOR=Tu nombre
# JSON array for WebRTC ICE servers.
# Example with STUN + TURN:
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
# Optional override for the sidebar “Upcoming streams” widget. If unset, the backend uses your
# Twitch login after you sign in with Twitch (users.twitch_username), then SCHEDULER_DEFAULT_STREAMER_USERNAME.
# VITE_SCHEDULER_STREAMER_USERNAME=yourname
#
# --- Tauri desktop (npm run tauri:dev / tauri:build) ---
# Same variables as above: the shell loads the Vite build; point VITE_API_URL at your backend (e.g. http://localhost:3000).
# Requires Rust: https://rustup.rs/ — then: cd frontend && npm run tauri:dev
# Optional: full URL shown on the landing “Native desktop” card (“Open build instructions”). Example:
# VITE_DESKTOP_BUILD_DOCS_URL=https://github.com/your-org/AkoNet/blob/main/frontend/README.md#app-de-escritorio-tauri
# Optional: URL to a hosted Tauri bundle (.exe setup or .msi) — shows “Download Windows installer” on the public landing.
# Example (GitHub Release): VITE_DESKTOP_INSTALLER_URL=https://github.com/your-org/AkoNet/releases/download/v0.3.0/AkoeNet_0.3.0_x64-setup.exe
# Or a file under your static host: VITE_DESKTOP_INSTALLER_URL=https://your-frontend.example.com/releases/AkoeNet_0.3.0_x64-setup.exe
# Same origin: copy the binary into public/releases/ and use a root path (no domain), e.g.:
# VITE_DESKTOP_INSTALLER_URL=/releases/akonet-desktop.exe
