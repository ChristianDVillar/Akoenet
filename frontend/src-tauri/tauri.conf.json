{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AkoeNet",
  "version": "0.7.8",
  "identifier": "com.akoenet.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AkoeNet",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost https: wss: http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* ws://127.0.0.1 ws://localhost https://id.twitch.tv https://api.twitch.tv",
        "img-src": "'self' asset: http://asset.localhost blob: data: https:",
        "media-src": "'self' blob: asset: http://asset.localhost",
        "style-src": "'unsafe-inline' 'self'",
        "font-src": "'self' data: https://fonts.gstatic.com",
        "frame-src": "'self' https:",
        "worker-src": "'self' blob:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEOTU5NUQ3QkUwODI5MTMKUldRVEtRaSsxNVdWZlZlKzdzeTEwbmV1amhEbCtUWDA0MHdDcEpxbUlhcTR5bGN4OWZBcGl2OHMK",
      "endpoints": [
        "https://github.com/ChristianDVillar/Akoenet/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
