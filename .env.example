# Copy this file to `.env` at the repo root if you use docker-compose only
# (${VAR} substitution). The `backend` service also loads `backend/.env` (env_file):
# put TWITCH_* and credentials there; keys in docker-compose.yml such as DATABASE_URL
# still override values from that file.

JWT_SECRET=change-me-in-production
TOKEN_VERSION=2
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
# Optional overrides; see backend/.env.example (PUBLIC_API_URL, FRONTEND_URL, RENDER_EXTERNAL_URL).
# Producción Render (referencia): API https://akoenet-backend.onrender.com — SPA https://akoenet-frontend.onrender.com
# TWITCH_REDIRECT_URI=http://localhost:3000/auth/twitch/callback
# FRONTEND_OAUTH_REDIRECT=http://localhost:5173/auth/twitch/callback
PUBLIC_API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
