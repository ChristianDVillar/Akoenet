node_modules/
**/node_modules/

# --- Variables de entorno ---
# Cubre .env en raíz y subcarpetas, y variantes (.env.local, .env.production, etc.).
.env
**/.env
.env.*
**/.env.*
# Plantillas de ejemplo (sin secretos): suelen subirse al repo; quita estas dos
# líneas si también quieres ignorar *.example.
!.env.example
!**/.env.example

backend/uploads/
dist/
**/dist/
*.log

# Notas locales (no subir)
AkoeNet-notes.txt
# Archivo suelto heredado de merges (p. ej. credenciales); no volver a añadir
/AkoNet
docs/notes/**
!docs/notes/README.md

# Firebase: el build Android usa frontend/android/app/google-services.json
# en local/CI; no versionar (metadatos de proyecto / clave API del cliente).
/google-services.json
frontend/android/app/google-services.json

# Firma Android: no versionar secretos ni keystores locales
frontend/android/key.properties
frontend/android/app/*.jks
